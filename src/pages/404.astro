---
import BaseLayout from "../layouts/BaseLayout.astro";
---
<BaseLayout
  title="404 — Not Found"
  description="This page does not exist."
  canonicalPath="/404"
>
  <div class="py-20">
    <h1 class="text-4xl font-semibold tracking-tight">404</h1>
    <p class="mt-4 text-black/70 dark:text-white/70">That page doesn’t exist.</p>
    <a class="mt-8 inline-block hover:underline underline-offset-4" href="/">Go home</a>
  </div>
</BaseLayout>
