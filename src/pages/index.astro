---
import BaseLayout from "../layouts/BaseLayout.astro";
import Section from "../components/Section.astro";
import Card from "../components/Card.astro";
import Badge from "../components/Badge.astro";
import SocialIcon from "../components/SocialIcon.astro";
import { site } from "../data/site";

const initials = site.name
  .split(" ")
  .filter(Boolean)
  .slice(0, 2)
  .map((x) => x[0]?.toUpperCase())
  .join("");

const terminalRows = [
  { key: "focus", value: "Reliable decision systems" },
  { key: "methods", value: "Optimization | ML | agents | simulation" },
  { key: "engineering", value: "Python packages, experiments, validation loops" },
  { key: "domain", value: "Control, energy, scheduling, digital twins" }
];

const stackRows = [
  ["LANG", "Python, TypeScript"],
  ["OPT", "Pyomo, MILP/MINLP, decomposition"],
  ["ML", "Evaluation, uncertainty, surrogates"],
  ["SYS", "Git, Docker, CI/CD, Linux"]
];

const dashboardRows = [
  ["BUILD", "research software"],
  ["MODEL", "optimization + ML"],
  ["VALIDATE", "simulation checks"],
  ["OUTPUT", "papers + code"]
];

const capabilityBars = [
  { label: "software", width: 86, color: "var(--blue)" },
  { label: "modeling", width: 80, color: "var(--green)" },
  { label: "validation", width: 82, color: "var(--amber)" }
];
---

<BaseLayout title={`${site.name} - ${site.title}`} description={site.tagline} canonicalPath="/">
  <div class="pointer-events-none fixed inset-0 -z-10 quant-grid"></div>

  <section id="top" class="py-10 sm:py-14">
    <div class="grid gap-4 lg:grid-cols-[1.05fr_0.95fr]">
      <div class="panel p-5 sm:p-7">
        <div class="flex flex-col gap-5 sm:flex-row sm:items-start">
          {
            site.avatar ? (
              <img
                src={site.avatar}
                alt={`${site.name} profile photo`}
                class="h-24 w-24 rounded-lg border border-black/10 object-cover dark:border-white/10"
                loading="eager"
              />
            ) : (
              <div class="flex h-24 w-24 items-center justify-center rounded-lg border border-black/10 bg-white/70 text-xl font-semibold dark:border-white/10 dark:bg-white/5">
                {initials}
              </div>
            )
          }

          <div class="min-w-0">
            <p class="mono-label">{site.location} / tech + quantitative research</p>
            <h1 class="mt-2 text-4xl font-semibold sm:text-6xl">{site.name}</h1>
            <p class="mt-3 max-w-2xl text-lg text-black/80 dark:text-white/80">{site.title}</p>
          </div>
        </div>

        <p class="mt-6 max-w-3xl text-base leading-7 text-black/70 dark:text-white/70">{site.tagline}</p>

        <div class="mt-5 flex flex-wrap gap-2">
          {site.badges?.map((badge) => <Badge>{badge}</Badge>)}
        </div>

        <div class="mt-6 flex flex-wrap gap-2">
          {
            site.ctas.map((c) => (
              <a
                class={`rounded-md border px-3.5 py-2 text-sm font-semibold transition ${
                  c.kind === "primary"
                    ? "border-black bg-black text-white hover:bg-black/85 dark:border-white dark:bg-white dark:text-black dark:hover:bg-white/85"
                    : "border-black/10 bg-white/50 text-black/75 hover:border-emerald-700/40 hover:text-black dark:border-white/10 dark:bg-white/5 dark:text-white/75 dark:hover:border-emerald-300/40 dark:hover:text-white"
                }`}
                href={c.href}
              >
                {c.label}
              </a>
            ))
          }
        </div>
      </div>

      <aside class="panel overflow-hidden">
        <div class="flex items-center justify-between border-b border-black/10 px-5 py-3 dark:border-white/10">
          <p class="font-mono text-sm font-semibold">SYSTEM_PROFILE</p>
          <div class="flex items-center gap-2 font-mono text-xs text-emerald-700 dark:text-emerald-300">
            <span class="h-1.5 w-1.5 rounded-full bg-emerald-600 dark:bg-emerald-300"></span>
            ACTIVE
          </div>
        </div>

        <div class="divide-y divide-black/10 dark:divide-white/10">
          {
            terminalRows.map((row) => (
              <div class="grid grid-cols-[8.5rem_1fr] gap-3 px-5 py-3 text-sm">
                <span class="font-mono text-black/50 dark:text-white/50">{row.key}</span>
                <span class="font-medium">{row.value}</span>
              </div>
            ))
          }
        </div>

        <div class="border-t border-black/10 bg-black/[0.03] p-5 dark:border-white/10 dark:bg-white/[0.03]">
          <p class="mono-label">operating principle</p>
          <p class="mt-3 font-mono text-sm leading-6 text-black/75 dark:text-white/75">
            build systems where model output, constraints, and validation are part of the same loop
          </p>
        </div>

        <div class="grid border-t border-black/10 text-xs dark:border-white/10 sm:grid-cols-2">
          <div class="border-b border-black/10 p-5 dark:border-white/10 sm:border-b-0 sm:border-r">
            <p class="mono-label">working style</p>
            <div class="mt-3 grid gap-2">
              {
                dashboardRows.map(([k, v]) => (
                  <div class="flex items-center justify-between gap-3">
                    <span class="font-mono text-black/50 dark:text-white/50">{k}</span>
                    <span class="font-semibold">{v}</span>
                  </div>
                ))
              }
            </div>
          </div>

          <div class="p-5">
            <p class="mono-label">capability mix</p>
            <div class="mt-3 space-y-3">
              {
                capabilityBars.map((bar) => (
                  <div>
                    <div class="mb-1 flex items-center justify-between font-mono text-[0.68rem] text-black/50 dark:text-white/50">
                      <span>{bar.label}</span>
                      <span>{bar.width}%</span>
                    </div>
                    <div class="h-1.5 rounded-sm bg-black/10 dark:bg-white/10">
                      <div class="h-1.5 rounded-sm" style={`width: ${bar.width}%; background: ${bar.color}`}></div>
                    </div>
                  </div>
                ))
              }
            </div>
          </div>
        </div>
      </aside>
    </div>

    <div class="mt-4 grid gap-3 sm:grid-cols-3">
      {
        site.highlights.map((h) => (
          <div class="panel panel-hover p-5">
            <p class="mono-label">{h.label}</p>
            <p class="mt-2 text-lg font-semibold">{h.value}</p>
            {h.hint && <p class="mt-2 text-sm leading-6 text-black/60 dark:text-white/60">{h.hint}</p>}
          </div>
        ))
      }
    </div>
  </section>

  <Section
    id="projects"
    title="Selected Work"
    subtitle="A curated set of research systems and open-source projects across ML, optimization, validation, and process intelligence."
  >
    <div class="grid gap-4 lg:grid-cols-2">
      {
        site.projects.map((p) => (
          <Card title={p.title} href={p.href ?? p.repo}>
            <p>{p.blurb}</p>

            {p.metrics?.length ? (
              <div class="mt-4 divide-y divide-black/10 border-y border-black/10 text-xs dark:divide-white/10 dark:border-white/10">
                {p.metrics.map((m) => (
                  <div class="grid grid-cols-[5.5rem_1fr] gap-2 py-2">
                    <span class="font-mono text-black/50 dark:text-white/50">{m.label}</span>
                    <span class="metric-value font-semibold text-black/80 dark:text-white/80">{m.value}</span>
                  </div>
                ))}
              </div>
            ) : null}

            <div class="mt-4 flex flex-wrap gap-2">
              {p.tags.map((t) => (
                <Badge>{t}</Badge>
              ))}
            </div>

            {(p.href || p.repo) && (
              <div class="mt-4 flex flex-wrap gap-2 text-xs font-semibold">
                {p.href && (
                  <a
                    class="rounded-md border border-black/10 px-2.5 py-1.5 hover:border-emerald-700/40 dark:border-white/10 dark:hover:border-emerald-300/40"
                    href={p.href}
                  >
                    Details
                  </a>
                )}
                {p.repo && (
                  <a
                    class="rounded-md border border-black/10 px-2.5 py-1.5 hover:border-emerald-700/40 dark:border-white/10 dark:hover:border-emerald-300/40"
                    href={p.repo}
                  >
                    Repo
                  </a>
                )}
              </div>
            )}

            {p.highlights?.length ? (
              <ul class="mt-4 space-y-2 border-t border-black/10 pt-4 text-xs leading-5 text-black/60 dark:border-white/10 dark:text-white/60">
                {p.highlights.map((x) => (
                  <li>{x}</li>
                ))}
              </ul>
            ) : null}
          </Card>
        ))
      }
    </div>
  </Section>

  <Section
    id="research"
    title="Selected Research"
    subtitle="Key papers and preprints. The full list remains available on Google Scholar."
  >
    <div class="grid gap-4 lg:grid-cols-[1.4fr_0.6fr]">
      <div class="panel p-5">
        <div class="grid grid-cols-[4.5rem_1fr] border-b border-black/10 pb-3 text-xs font-semibold uppercase text-black/45 dark:border-white/10 dark:text-white/45 sm:grid-cols-[5rem_1fr_8rem]">
          <span>Year</span>
          <span>Paper</span>
          <span class="hidden sm:block">Type</span>
        </div>

        <ul class="divide-y divide-black/10 dark:divide-white/10">
          {
            site.publications?.map((p) => (
              <li class="grid grid-cols-[4.5rem_1fr] gap-3 py-4 text-sm sm:grid-cols-[5rem_1fr_8rem]">
                <span class="metric-value text-black/50 dark:text-white/50">{p.year}</span>
                <div>
                  <a class="font-semibold hover:underline underline-offset-4" href={p.href ?? site.scholarUrl}>
                    {p.title}
                  </a>
                  <div class="mt-1 text-xs text-black/60 dark:text-white/60">
                    {[p.venue, p.note].filter(Boolean).join(" / ")}
                  </div>
                  {p.links?.length ? (
                    <div class="mt-2 flex flex-wrap gap-2">
                      {p.links.map((link) => (
                        <a
                          class="rounded-md border border-black/10 px-2 py-1 text-xs font-semibold hover:border-emerald-700/40 dark:border-white/10 dark:hover:border-emerald-300/40"
                          href={link.href}
                        >
                          {link.label}
                        </a>
                      ))}
                    </div>
                  ) : null}
                </div>
                <span class="hidden text-xs text-black/50 dark:text-white/50 sm:block">{p.note}</span>
              </li>
            ))
          }
        </ul>
      </div>

      <div class="panel p-5">
        <p class="mono-label">current positions</p>
        <ul class="mt-4 space-y-4 text-sm">
          {
            site.pipeline?.map((x) => (
              <li class="border-l-2 border-emerald-700/50 pl-3 dark:border-emerald-300/50">
                <div class="font-semibold">{x.title}</div>
                <div class="mt-1 leading-6 text-black/60 dark:text-white/60">{x.blurb}</div>
              </li>
            ))
          }
        </ul>

        <a
          class="mt-5 inline-flex rounded-md border border-black/10 px-3 py-2 text-sm font-semibold hover:border-emerald-700/40 dark:border-white/10 dark:hover:border-emerald-300/40"
          href={site.scholarUrl}
        >
          Google Scholar
        </a>
      </div>
    </div>
  </Section>

  <Section
    id="writing"
    title="Notes"
    subtitle="Public writing and maintained profiles for research context."
  >
    <div class="grid gap-4 md:grid-cols-2">
      {
        site.writing.map((w) => (
          <Card title={w.title} href={w.href}>
            <div class="flex flex-wrap gap-x-3 gap-y-1 font-mono text-xs text-black/50 dark:text-white/50">
              {w.venue && <span>{w.venue}</span>}
              {w.year && <span>{w.year}</span>}
            </div>
            {w.blurb && <p class="mt-3">{w.blurb}</p>}
          </Card>
        ))
      }
    </div>
  </Section>

  <Section id="skills" title="Stack" subtitle="A compact toolchain for quantitative modelling and reliable decision systems.">
    <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-5">
      {
        site.skills.map((g) => (
          <div class="panel panel-hover p-5">
            <p class="font-semibold">{g.group}</p>
            <div class="mt-4 flex flex-wrap gap-2">
              {g.items.map((i) => (
                <Badge>{i}</Badge>
              ))}
            </div>
          </div>
        ))
      }
    </div>

    <div class="panel mt-4 overflow-hidden">
      <div class="grid divide-y divide-black/10 text-sm dark:divide-white/10 sm:grid-cols-4 sm:divide-x sm:divide-y-0">
        {
          stackRows.map(([k, v]) => (
            <div class="p-4">
              <p class="font-mono text-xs text-black/50 dark:text-white/50">{k}</p>
              <p class="mt-2 font-semibold">{v}</p>
            </div>
          ))
        }
      </div>
    </div>
  </Section>

  <Section
    id="contact"
    title="Contact"
    subtitle="For quantitative ML, optimization, controls, and decision-system conversations."
  >
    <div class="panel grid gap-4 p-5 sm:grid-cols-[1fr_auto] sm:items-center">
      <div>
        <p class="mono-label">contact route</p>
        <a class="mt-2 inline-block text-lg font-semibold hover:underline underline-offset-4" href={`mailto:${site.email}`}>
          {site.email}
        </a>
      </div>
      <div class="flex flex-wrap gap-3 text-sm">
        {site.socials.map((s) => (
          <a class="group inline-flex items-center gap-2 hover:underline underline-offset-4" href={s.href}>
            <SocialIcon kind={s.icon} />
            <span>{s.label}</span>
          </a>
        ))}
      </div>
    </div>
  </Section>
</BaseLayout>
