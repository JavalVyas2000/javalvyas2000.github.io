---
import BaseLayout from "../layouts/BaseLayout.astro";
import Section from "../components/Section.astro";
import Card from "../components/Card.astro";
import Badge from "../components/Badge.astro";
import { site } from "../data/site";
---
<BaseLayout
  title={`${site.name} — ${site.title}`}
  description={site.tagline}
  canonicalPath="/"
>
  <div id="top" class="py-12 sm:py-16">
    <div class="rounded-[2rem] border border-black/10 dark:border-white/10 bg-gradient-to-b from-black/[0.03] to-transparent dark:from-white/[0.06] p-8 sm:p-12">
      <div class="max-w-2xl">
        <p class="text-sm text-black/60 dark:text-white/60">{site.location}</p>
        <h1 class="mt-3 text-3xl sm:text-5xl font-semibold tracking-tight">
          {site.name}
        </h1>
        <p class="mt-3 text-lg sm:text-xl text-black/80 dark:text-white/80">
          {site.title}
        </p>
        <p class="mt-5 text-black/70 dark:text-white/70 leading-relaxed">
          {site.tagline}
        </p>

        <div class="mt-7 flex flex-wrap gap-3">
          {site.ctas.map((c) => (
            <a
              class={`rounded-2xl px-4 py-2 text-sm transition border ${
                c.kind === "primary"
                  ? "bg-black text-white border-black hover:opacity-90 dark:bg-white dark:text-black dark:border-white"
                  : "border-black/10 dark:border-white/10 hover:bg-black/5 dark:hover:bg-white/5"
              }`}
              href={c.href}
            >
              {c.label}
            </a>
          ))}
        </div>

        <div class="mt-8 flex flex-wrap gap-2">
          {site.socials.map((s) => (
            <a class="text-sm hover:underline underline-offset-4 text-black/70 dark:text-white/70" href={s.href}>
              {s.label}
            </a>
          ))}
          <a class="text-sm hover:underline underline-offset-4 text-black/70 dark:text-white/70" href={`mailto:${site.email}`}>
            Email
          </a>
        </div>
      </div>
    </div>

    <div class="mt-8 grid gap-4 sm:grid-cols-3">
      {site.highlights.map((h) => (
        <div class="rounded-3xl border border-black/10 dark:border-white/10 p-5 bg-white/50 dark:bg-black/20 backdrop-blur">
          <p class="text-sm text-black/60 dark:text-white/60">{h.label}</p>
          <p class="mt-2 font-semibold">{h.value}</p>
          {h.hint && <p class="mt-1 text-sm text-black/60 dark:text-white/60">{h.hint}</p>}
        </div>
      ))}
    </div>
  </div>

  <Section
    id="projects"
    title="Selected Work"
    subtitle="A compact set of projects that show how I think: research → evaluation → implementation."
  >
    <div class="grid gap-4 sm:grid-cols-2">
      {site.projects.map((p) => (
        <Card title={p.title} href={p.href ?? p.repo}>
          <p class="leading-relaxed">{p.blurb}</p>

          <div class="mt-4 flex flex-wrap gap-2">
            {p.tags.map((t) => (
              <Badge>{t}</Badge>
            ))}
          </div>

          {(p.href || p.repo) && (
            <div class="mt-4 flex flex-wrap gap-3 text-sm">
              {p.href && (
                <a class="hover:underline underline-offset-4" href={p.href}>
                  Live / Details
                </a>
              )}
              {p.repo && (
                <a class="hover:underline underline-offset-4" href={p.repo}>
                  Repo
                </a>
              )}
            </div>
          )}

          {p.highlights?.length ? (
            <ul class="mt-4 list-disc pl-5 text-sm text-black/65 dark:text-white/65">
              {p.highlights.map((x) => (
                <li>{x}</li>
              ))}
            </ul>
          ) : null}
        </Card>
      ))}
    </div>
  </Section>

  <Section
    id="writing"
    title="Research / Notes"
    subtitle="Short, pragmatic write-ups: how to validate, how to avoid leakage, how to ship."
  >
    <div class="grid gap-4">
      {site.writing.map((w) => (
        <Card title={w.title} href={w.href}>
          <div class="flex flex-wrap gap-x-3 gap-y-1 text-sm text-black/60 dark:text-white/60">
            {w.venue && <span>{w.venue}</span>}
            {w.year && <span>• {w.year}</span>}
          </div>
          {w.blurb && <p class="mt-3">{w.blurb}</p>}
        </Card>
      ))}
    </div>
  </Section>

  <Section
    id="skills"
    title="Skills"
    subtitle="The stack I reach for when building research-grade and production-grade work."
  >
    <div class="grid gap-4 sm:grid-cols-3">
      {site.skills.map((g) => (
        <div class="rounded-3xl border border-black/10 dark:border-white/10 p-6 bg-white/50 dark:bg-black/20 backdrop-blur">
          <p class="font-semibold">{g.group}</p>
          <div class="mt-4 flex flex-wrap gap-2">
            {g.items.map((i) => (
              <Badge>{i}</Badge>
            ))}
          </div>
        </div>
      ))}
    </div>
  </Section>

  <Section
    id="contact"
    title="Contact"
    subtitle="If you’re building something technical in markets/data, I’m happy to chat."
  >
    <div class="rounded-3xl border border-black/10 dark:border-white/10 p-6 bg-white/50 dark:bg-black/20 backdrop-blur">
      <p class="text-black/70 dark:text-white/70">
        Best way to reach me:{" "}
        <a class="font-semibold hover:underline underline-offset-4" href={`mailto:${site.email}`}>
          {site.email}
        </a>
      </p>

      <div class="mt-4 flex flex-wrap gap-3 text-sm">
        {site.socials.map((s) => (
          <a class="hover:underline underline-offset-4" href={s.href}>
            {s.label}
          </a>
        ))}
      </div>

      <p class="mt-6 text-sm text-black/60 dark:text-white/60">
        Tip: update your content in <code class="px-1 py-0.5 rounded bg-black/5 dark:bg-white/10">src/data/site.ts</code>.
      </p>
    </div>
  </Section>
</BaseLayout>
