---
// FILE: src/pages/index.astro
import BaseLayout from "../layouts/BaseLayout.astro";
import Section from "../components/Section.astro";
import Card from "../components/Card.astro";
import Badge from "../components/Badge.astro";
import { site } from "../data/site";

const initials = site.name
  .split(" ")
  .filter(Boolean)
  .slice(0, 2)
  .map((x) => x[0]?.toUpperCase())
  .join("");
---
<BaseLayout title={`${site.name} — ${site.title}`} description={site.tagline} canonicalPath="/">
  <div class="pointer-events-none fixed inset-0 -z-10">
    <div class="absolute inset-0 bg-grid opacity-[0.35] dark:opacity-[0.25]"></div>
    <div class="absolute -top-20 -left-24 h-72 w-72 rounded-full bg-black/30 dark:bg-white/20 glow floaty"></div>
    <div
      class="absolute top-52 -right-24 h-80 w-80 rounded-full bg-black/20 dark:bg-white/15 glow floaty"
      style="animation-delay: 1.2s"
    ></div>
  </div>

  <div id="top" class="py-12 sm:py-16">
    <div class="rounded-[2rem] border border-black/10 dark:border-white/10 bg-white/70 dark:bg-black/30 backdrop-blur p-8 sm:p-12">
      <div class="flex flex-col sm:flex-row sm:items-center gap-7">
        <div class="shrink-0">
          {site.avatar ? (
            <img
              src={site.avatar}
              alt={`${site.name} profile photo`}
              class="h-28 w-28 sm:h-32 sm:w-32 rounded-full object-cover border border-black/10 dark:border-white/10 shadow-sm"
              loading="eager"
            />
          ) : (
            <div class="h-28 w-28 sm:h-32 sm:w-32 rounded-full border border-black/10 dark:border-white/10 bg-white/60 dark:bg-black/20 backdrop-blur flex items-center justify-center text-xl font-semibold shadow-sm">
              {initials}
            </div>
          )}
        </div>

        <div class="max-w-2xl">
          <p class="text-sm text-black/60 dark:text-white/60">{site.location}</p>
          <h1 class="mt-2 text-3xl sm:text-5xl font-semibold tracking-tight">{site.name}</h1>
          <p class="mt-3 text-lg sm:text-xl text-black/80 dark:text-white/80">{site.title}</p>
          <p class="mt-5 text-black/70 dark:text-white/70 leading-relaxed">{site.tagline}</p>

          {site.badges?.length ? (
            <div class="mt-5 flex flex-wrap gap-2">
              {site.badges.map((b) => (
                <span class="inline-flex items-center rounded-full border border-black/10 dark:border-white/10 px-3 py-1 text-xs bg-white/55 dark:bg-black/15 backdrop-blur hover:bg-black/5 dark:hover:bg-white/5 transition">
                  {b}
                </span>
              ))}
            </div>
          ) : null}

          <div class="mt-7 flex flex-wrap gap-3">
            {site.ctas.map((c) => (
              <a
                class={`rounded-2xl px-4 py-2 text-sm transition border ${
                  c.kind === "primary"
                    ? "bg-black text-white border-black hover:opacity-90 dark:bg-white dark:text-black dark:border-white"
                    : "border-black/10 dark:border-white/10 hover:bg-black/5 dark:hover:bg-white/5"
                }`}
                href={c.href}
              >
                {c.label}
              </a>
            ))}
          </div>

          <div class="mt-7 flex flex-wrap gap-2">
            {site.socials.map((s) => (
              <a class="text-sm hover:underline underline-offset-4 text-black/70 dark:text-white/70" href={s.href}>
                {s.label}
              </a>
            ))}
            <a class="text-sm hover:underline underline-offset-4 text-black/70 dark:text-white/70" href={`mailto:${site.email}`}>
              Email
            </a>
          </div>
        </div>
      </div>
    </div>

    <div class="mt-8 grid gap-4 sm:grid-cols-3">
      {site.highlights.map((h) => (
        <div class="rounded-3xl border border-black/10 dark:border-white/10 p-6 bg-white/60 dark:bg-black/25 backdrop-blur shadow-sm hover:shadow-md transition">
          <p class="text-sm text-black/60 dark:text-white/60">{h.label}</p>
          <p class="mt-2 font-semibold">{h.value}</p>
          {h.hint && <p class="mt-2 text-sm text-black/60 dark:text-white/60">{h.hint}</p>}
        </div>
      ))}
    </div>
  </div>

  <Section id="projects" title="Selected Work" subtitle="Projects that show research discipline, evaluation, and engineering hygiene.">
    <div class="grid gap-4 sm:grid-cols-2">
      {site.projects.map((p) => (
        <Card title={p.title} href={p.href ?? p.repo}>
          <p class="leading-relaxed">{p.blurb}</p>

          {p.metrics?.length ? (
            <div class="mt-4 grid grid-cols-2 gap-2 text-sm">
              {p.metrics.map((m) => (
                <div class="rounded-2xl border border-black/10 dark:border-white/10 px-3 py-2 bg-white/50 dark:bg-black/20">
                  <p class="text-black/55 dark:text-white/55">{m.label}</p>
                  <p class="font-semibold">{m.value}</p>
                </div>
              ))}
            </div>
          ) : null}

          <div class="mt-4 flex flex-wrap gap-2">
            {p.tags.map((t) => (
              <Badge>{t}</Badge>
            ))}
          </div>

          {(p.href || p.repo) && (
            <div class="mt-4 flex flex-wrap gap-3 text-sm">
              {p.href && (
                <a class="hover:underline underline-offset-4" href={p.href}>
                  Live / Details
                </a>
              )}
              {p.repo && (
                <a class="hover:underline underline-offset-4" href={p.repo}>
                  Repo
                </a>
              )}
            </div>
          )}

          {p.highlights?.length ? (
            <ul class="mt-4 list-disc pl-5 text-sm text-black/65 dark:text-white/65">
              {p.highlights.map((x) => (
                <li>{x}</li>
              ))}
            </ul>
          ) : null}
        </Card>
      ))}
    </div>
  </Section>

  <Section id="writing" title="Research / Notes" subtitle="Short write-ups: what I tested, how I validated it, and what I’d ship.">
    <div class="grid gap-4">
      {site.writing.map((w) => (
        <Card title={w.title} href={w.href}>
          <div class="flex flex-wrap gap-x-3 gap-y-1 text-sm text-black/60 dark:text-white/60">
            {w.venue && <span>{w.venue}</span>}
            {w.year && <span>• {w.year}</span>}
          </div>
          {w.blurb && <p class="mt-3">{w.blurb}</p>}
        </Card>
      ))}
    </div>
  </Section>

  <Section id="skills" title="Skills" subtitle="A compact stack. I optimize for reproducibility, evaluation, and maintainability.">
    <div class="grid gap-4 sm:grid-cols-3">
      {site.skills.map((g) => (
        <div class="rounded-3xl border border-black/10 dark:border-white/10 p-6 bg-white/60 dark:bg-black/25 backdrop-blur shadow-sm hover:shadow-md transition">
          <p class="font-semibold">{g.group}</p>
          <div class="mt-4 flex flex-wrap gap-2">
            {g.items.map((i) => (
              <Badge>{i}</Badge>
            ))}
          </div>
        </div>
      ))}
    </div>
  </Section>

  <Section id="contact" title="Contact" subtitle="If you’re building something technical in markets/data, I’m happy to chat.">
    <div class="rounded-3xl border border-black/10 dark:border-white/10 p-6 bg-white/60 dark:bg-black/25 backdrop-blur shadow-sm">
      <p class="text-black/70 dark:text-white/70">
        Best way to reach me:{" "}
        <a class="font-semibold hover:underline underline-offset-4" href={`mailto:${site.email}`}>
          {site.email}
        </a>
      </p>

      <div class="mt-4 flex flex-wrap gap-3 text-sm">
        {site.socials.map((s) => (
          <a class="hover:underline underline-offset-4" href={s.href}>
            {s.label}
          </a>
        ))}
      </div>
    </div>
  </Section>
</BaseLayout>