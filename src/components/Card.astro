---
const { title, href } = Astro.props as { title: string; href?: string };
---
<div class="rounded-3xl border border-black/10 dark:border-white/10 bg-white/60 dark:bg-black/20 backdrop-blur p-6 shadow-sm">
  <div class="flex items-start justify-between gap-4">
    <h3 class="text-lg font-semibold tracking-tight">
      {href ? (
        <a class="hover:underline underline-offset-4" href={href}>
          {title}
        </a>
      ) : (
        title
      )}
    </h3>
    <slot name="corner" />
  </div>
  <div class="mt-3 text-black/70 dark:text-white/70">
    <slot />
  </div>
</div>
