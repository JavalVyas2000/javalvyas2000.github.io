---
const { title, href } = Astro.props as { title: string; href?: string };
---
<div class="panel panel-hover p-5">
  <div class="flex items-start justify-between gap-4">
    <h3 class="text-base font-semibold">
      {href ? (
        <a class="hover:underline underline-offset-4" href={href}>
          {title}
        </a>
      ) : (
        title
      )}
    </h3>
    <slot name="corner" />
  </div>
  <div class="mt-3 text-sm leading-relaxed text-black/70 dark:text-white/70">
    <slot />
  </div>
</div>
