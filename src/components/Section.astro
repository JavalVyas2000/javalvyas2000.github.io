---
const { id, title, subtitle } = Astro.props as { id?: string; title: string; subtitle?: string };
---
<section id={id} class="scroll-mt-24 py-9">
  <div class="mb-5 border-b border-black/10 pb-3 dark:border-white/10">
    <p class="mono-label">module</p>
    <div class="mt-1 flex flex-col gap-2 sm:flex-row sm:items-end sm:justify-between">
      <h2 class="text-2xl font-semibold sm:text-3xl">{title}</h2>
      {subtitle && <p class="max-w-2xl text-sm text-black/60 dark:text-white/60 sm:text-right">{subtitle}</p>}
    </div>
  </div>
  <slot />
</section>
