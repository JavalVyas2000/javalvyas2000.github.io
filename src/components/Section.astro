---
const { id, title, subtitle } = Astro.props as { id?: string; title: string; subtitle?: string };
---
<section id={id} class="scroll-mt-24 py-10">
  <div class="mb-6">
    <h2 class="text-2xl sm:text-3xl font-semibold tracking-tight">{title}</h2>
    {subtitle && <p class="mt-2 text-black/70 dark:text-white/70 max-w-2xl">{subtitle}</p>}
  </div>
  <slot />
</section>
