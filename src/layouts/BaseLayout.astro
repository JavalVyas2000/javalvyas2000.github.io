---
import "../styles/global.css";
import Nav from "../components/Nav.astro";
import { absoluteUrl } from "../utils/seo";

const {
  title,
  description,
  ogTitle,
  ogDescription,
  ogImage = "/og.png",
  canonicalPath = "/"
} = Astro.props as {
  title: string;
  description: string;
  ogTitle?: string;
  ogDescription?: string;
  ogImage?: string;
  canonicalPath?: string;
};

const finalOgTitle = ogTitle ?? title;
const finalOgDesc = ogDescription ?? description;
---
<!doctype html>
<html lang="en" class="bg-[#f7f8fa] text-[#101418] dark:bg-[#090b0c] dark:text-[#edf0ed]">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={absoluteUrl(canonicalPath)} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={finalOgTitle} />
    <meta property="og:description" content={finalOgDesc} />
    <meta property="og:url" content={absoluteUrl(canonicalPath)} />
    <meta property="og:image" content={absoluteUrl(ogImage)} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={finalOgTitle} />
    <meta name="twitter:description" content={finalOgDesc} />
    <meta name="twitter:image" content={absoluteUrl(ogImage)} />

    <title>{title}</title>
  </head>
  <body class="antialiased">
    <Nav />
    <main class="mx-auto max-w-6xl px-4 sm:px-6">
      <slot />
    </main>
    <footer class="mx-auto max-w-6xl px-4 py-10 font-mono text-xs text-black/55 dark:text-white/55 sm:px-6">
      <div class="flex flex-col gap-2 border-t border-black/10 pt-5 dark:border-white/10 sm:flex-row sm:items-center sm:justify-between">
        <span>&copy; {new Date().getFullYear()} - Built with Astro</span>
        <a class="hover:text-black dark:hover:text-white" href="#top">BACK_TO_TOP</a>
      </div>
    </footer>
  </body>
</html>
